# =============================================================================
# PyRIT MCP Server — Docker-specific Environment Template
# Copy to .env.docker and use with: docker compose --env-file .env.docker up
#
# This file sets values appropriate for running inside Docker Compose.
# Service names (ollama, pyrit-scorer) are used as hostnames.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PYRIT_DB_PATH=/data/pyrit.db
PYRIT_LOG_LEVEL=INFO
PYRIT_DEFAULT_RPS=2
PYRIT_DEFAULT_MAX_REQUESTS=100
PYRIT_SANDBOX_MODE=false

# ── Attacker (Docker service hostname) ───────────────────────────────────────
ATTACKER_BACKEND=ollama
ATTACKER_BASE_URL=http://ollama:11434
ATTACKER_MODEL=dolphin-mistral
ATTACKER_API_KEY_ENV=
ATTACKER_TEMPERATURE=1.0
ATTACKER_MAX_TOKENS=2048
ATTACKER_TIMEOUT=60

# ── Scorer ───────────────────────────────────────────────────────────────────
SCORER_BACKEND=openai
SCORER_BASE_URL=https://api.openai.com/v1
SCORER_MODEL=gpt-4o
SCORER_API_KEY_ENV=SCORER_OPENAI_API_KEY
SCORER_TEMPERATURE=0.0

# API key value (referenced by SCORER_API_KEY_ENV above)
SCORER_OPENAI_API_KEY=sk-...

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=dolphin-mistral
OLLAMA_SCORER_MODEL=
OLLAMA_GPU_LAYERS=-1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_FLASH_ATTENTION=false
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_NUM_THREADS=4
OLLAMA_RUNNER_NUMCTX=2048

# ── llama.cpp ─────────────────────────────────────────────────────────────────
LLAMACPP_MODEL_PATH=/models/model.gguf
LLAMACPP_N_THREADS=8
LLAMACPP_CTX_SIZE=4096
LLAMACPP_BATCH_SIZE=512
LLAMACPP_N_PARALLEL=1
LLAMACPP_MLOCK=false
LLAMACPP_MMAP=true
LLAMACPP_NUMA=
LLAMACPP_N_GPU_LAYERS=0
LLAMACPP_PORT=8080
