# =============================================================================
# PyRIT MCP Server — Environment Configuration Template
# Copy this file to .env and fill in your values.
#
# SECURITY: .env is in .gitignore and MUST NEVER be committed to git.
# Credentials are only passed as the NAME of an env var, never as raw values
# in tool parameters, ensuring keys never appear in MCP conversation logs.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PYRIT_DB_PATH=/data/pyrit.db          # DuckDB session file path inside container
PYRIT_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
PYRIT_DEFAULT_RPS=2                   # Default requests/second for attack campaigns
PYRIT_DEFAULT_MAX_REQUESTS=100        # Default max requests per campaign
PYRIT_SANDBOX_MODE=false              # true = log prompts but send NO real requests

# ── Attacker LLM Backend ──────────────────────────────────────────────────────
# The attacker generates adversarial prompts. Must be uncensored or minimally filtered.
# Options: ollama | llamacpp | azure | openai | groq | lmstudio
ATTACKER_BACKEND=ollama
ATTACKER_BASE_URL=http://ollama:11434    # Ollama default; change for other backends
ATTACKER_MODEL=dolphin-mistral           # Model identifier (Ollama pull name or API model ID)
ATTACKER_API_KEY_ENV=                    # Name of env var holding the API key; blank for Ollama
ATTACKER_TEMPERATURE=1.0                 # Higher = more creative attack generation
ATTACKER_MAX_TOKENS=2048
ATTACKER_TIMEOUT=60
ATTACKER_QUANTIZATION=Q4_K_M            # Informational only — used for logging

# ── Scorer LLM Backend ────────────────────────────────────────────────────────
# The scorer evaluates whether attacks succeeded. Can be safety-filtered.
# Options: openai | azure | ollama | llamacpp | substring | classifier
SCORER_BACKEND=openai
SCORER_BASE_URL=https://api.openai.com/v1
SCORER_MODEL=gpt-4o
SCORER_API_KEY_ENV=SCORER_OPENAI_API_KEY  # Name of env var below
SCORER_TEMPERATURE=0.0                     # Zero for deterministic scoring
SCORER_QUANTIZATION=

# ── API Keys ──────────────────────────────────────────────────────────────────
# These are the ACTUAL key values referenced by the _API_KEY_ENV vars above.
# They are read server-side and never appear in MCP tool parameters.
SCORER_OPENAI_API_KEY=sk-...

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# Required if ATTACKER_BACKEND=azure or SCORER_BACKEND=azure
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_ATTACKER_DEPLOYMENT=
AZURE_SCORER_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-02-01
# Set to true only if enrolled in Microsoft's Limited Access content filter bypass program
AZURE_CONTENT_FILTER_OVERRIDE=false

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_ATTACKER_MODEL=mixtral-8x7b-32768

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=dolphin-mistral            # Attacker model — pulled by ollama-init container
OLLAMA_SCORER_MODEL=                    # Scorer model for dual-ollama profile; leave blank otherwise
OLLAMA_GPU_LAYERS=-1                    # -1 = all layers on GPU; 0 = CPU only
OLLAMA_NUM_PARALLEL=1                   # Concurrent request slots (increase for Tier 3+)
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_FLASH_ATTENTION=false            # Set true for Tier 3+ for significant speedup
OLLAMA_KV_CACHE_TYPE=q8_0              # q8_0 for Tier 1-2; f16 for Tier 3+
OLLAMA_NUM_THREADS=4                    # Physical CPU cores (not hyperthreaded count)
OLLAMA_RUNNER_NUMCTX=2048              # Context window size

# ── llama.cpp Direct (Tier 5/6/7 — full-llamacpp profile) ────────────────────
LLAMACPP_MODEL_PATH=/models/llama3.1-405b-Q8_0.gguf
LLAMACPP_SCORER_MODEL_PATH=/models/llama3.1-70b-Q6_K.gguf
LLAMACPP_N_THREADS=64                  # Use physical core count (not hyperthreaded)
LLAMACPP_CTX_SIZE=32768
LLAMACPP_BATCH_SIZE=512
LLAMACPP_N_PARALLEL=4
LLAMACPP_MLOCK=true                    # Lock model in RAM — requires unlimited mlock
LLAMACPP_MMAP=true
LLAMACPP_NUMA=distribute               # Use 'distribute' for dual-socket machines; blank for single
LLAMACPP_N_GPU_LAYERS=0               # 0 = CPU only; -1 = all layers to GPU
LLAMACPP_PORT=8080

# ── Per-Instance Config (dual-ollama / full-llamacpp profiles) ────────────────
ATTACKER_MODEL_FILE=llama3.1-405b-Q8_0.gguf
ATTACKER_QUANT=Q8_0
ATTACKER_RAM_ALLOCATION_GB=400
ATTACKER_N_THREADS=64
ATTACKER_CTX_SIZE=32768
ATTACKER_MLOCK=true

SCORER_MODEL_FILE=llama3.1-70b-Q6_K.gguf
SCORER_QUANT=Q6_K
SCORER_RAM_ALLOCATION_GB=48
SCORER_N_THREADS=32
SCORER_CTX_SIZE=8192
SCORER_MLOCK=true

# ── Target Application Credentials ────────────────────────────────────────────
# These are used by pyrit_configure_*_target tools via SCORER_API_KEY_ENV pattern
TARGET_BEARER_TOKEN=
TARGET_OPENAI_API_KEY=
TARGET_AZURE_API_KEY=
TARGET_AZURE_ENDPOINT=

# ── HuggingFace ───────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=                     # Required for gated model downloads (Meta-Llama, etc.)
