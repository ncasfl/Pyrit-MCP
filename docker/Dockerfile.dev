# =============================================================================
# PyRIT MCP Server — Development Image
#
# Extends the production image with:
#   - requirements-dev.txt (pytest, ruff, mypy, ipython, watchdog)
#   - Source code volume-mounted for hot reload without rebuilds
#   - DEBUG log level by default
#   - Port 5678 exposed for debugpy remote debugging
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up
#   make up-dev
#
# Hot reload: edit files in pyrit_mcp/ on the host; changes take effect
# immediately because the source is bind-mounted over the image copy.
# =============================================================================

FROM python:3.11-slim

# Layer 1: System dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gcc \
        libgomp1 \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Layer 2: Production Python dependencies
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Layer 3: PyRIT
RUN pip install --no-cache-dir pyrit

# Layer 4: Dev dependencies (separate layer — changes more often than prod deps)
COPY requirements-dev.txt /tmp/requirements-dev.txt
RUN pip install --no-cache-dir -r /tmp/requirements-dev.txt \
    && pip install --no-cache-dir watchdog debugpy

# Layer 5: Application code (will be overridden by volume mount in dev)
WORKDIR /app
COPY pyrit_mcp/ ./pyrit_mcp/

# Layer 6: Entrypoint
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Run as non-root user (same as production for parity)
RUN useradd --uid 1000 --no-create-home --shell /bin/false pyrit \
    && mkdir -p /data /datasets /models \
    && chown -R pyrit:pyrit /data /datasets /app
USER pyrit

# Volumes
VOLUME ["/data", "/datasets", "/models"]

# Debug port (debugpy)
EXPOSE 5678

# Development defaults
ENV PYRIT_LOG_LEVEL=DEBUG
ENV PYRIT_SANDBOX_MODE=true

ENTRYPOINT ["/entrypoint.sh"]
